{
  "entities": {
    "analysis": {
      "title": "Analysis Result",
      "description": "Stock image analysis result generated by AI",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "url": { "type": "string" },
        "score": { "type": "number" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "trends": { "type": "string" },
        "commercialPotential": { "type": "string" },
        "suggestions": { "type": "array", "items": { "type": "string" } },
        "editingGuide": {
          "type": "object",
          "properties": {
            "exposure": { "type": "string" },
            "contrast": { "type": "string" },
            "saturation": { "type": "string" },
            "highlights": { "type": "string" },
            "shadows": { "type": "string" },
            "colorTemp": { "type": "string" },
            "cropSuggestion": { "type": "string" }
          }
        },
        "timestamp": { "type": "number" }
      },
      "required": ["id", "userId", "name", "url", "score", "timestamp"]
    }
  },
  "firestore": {
    "analyses/{analysisId}": {
      "schema": "analysis",
      "description": "Analysis results for stock images"
    },
    "user_settings/{userId}": {
      "schema": "user_settings",
      "description": "User specific integration settings"
    }
  },
